# Database
MONGODB_URI=mongodb://localhost:27017/ntic-social

# JWT Secret
JWT_SECRET=your-super-secure-jwt-secret-key-here

# Server Configuration
NODE_ENV=production
PORT=3000

# CORS Configuration
ALLOWED_ORIGINS=https://yourdomain.com,https://dashboard.yourdomain.com

# Webhook Security
WEBHOOK_SECRET=your-webhook-secret-key

# Redis (for queue management)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# Social Media Platform API Keys

# LinkedIn
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Twitter/X
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# Facebook/Meta
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Instagram Business
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token

# YouTube
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret

# TikTok Business
TIKTOK_CLIENT_ID=your-tiktok-client-id
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# Pinterest
PINTEREST_APP_ID=your-pinterest-app-id
PINTEREST_APP_SECRET=your-pinterest-app-secret

# Upwork (for automation - use with caution)
UPWORK_AUTO_SUBMIT=false
UPWORK_PROFILE_NAME=Your Profile Name

# Fiverr (for automation - use with caution)
FIVERR_AUTO_SUBMIT=false
FIVERR_PROFILE_NAME=Your Profile Name

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
FROM_EMAIL=noreply@yourdomain.com

# File Storage
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=50MB

# Rate Limiting
API_RATE_LIMIT=1000
API_RATE_WINDOW=1h

# Analytics
GOOGLE_ANALYTICS_ID=your-ga-tracking-id

# Error Monitoring (optional)
SENTRY_DSN=your-sentry-dsn

# Feature Flags
ENABLE_AUTO_POSTING=true
ENABLE_ENGAGEMENT_AUTOMATION=true
ENABLE_PROPOSAL_AUTOMATION=false

# Security
SESSION_SECRET=your-session-secret
BCRYPT_ROUNDS=12

# Third-party Integrations
ZAPIER_WEBHOOK_URL=your-zapier-webhook-url
SLACK_WEBHOOK_URL=your-slack-webhook-url

# Content Generation (if using AI)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Analytics & Tracking
MIXPANEL_TOKEN=your-mixpanel-token
AMPLITUDE_API_KEY=your-amplitude-api-key